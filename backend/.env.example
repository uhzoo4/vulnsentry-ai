# VulnSentry AI — Production Configuration Example
# Copy this file to .env and configure the variables accordingly.

# 1. Gemini API Key Configuration
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# 2. Administrative Security
# Required if you want to protect administrative endpoints (e.g. /remediate) on localhost
API_SECRET=

# 3. CORS Network Settings
# Comma-separated list of allowed origins (e.g., http://localhost:5173,https://yourspace.hf.space)
# If empty, defaults to localhost development origins.
ALLOWED_ORIGINS=

# 4. Rate Limiting Control
# Set to 'false' to disable rate limits, defaults to 'true' otherwise.
RATE_LIMIT=true
